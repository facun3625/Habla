generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id             Int             @id @default(autoincrement())
  name           String          @unique
  description    String?
  createdAt      DateTime        @default(now())
  courseProfiles CourseProfile[]
  enrollments    Enrollment[]
  moduleAccess   ModuleAccess[]
  prices         Price[]
  users          User[]
}

model User {
  id               Int          @id @default(autoincrement())
  email            String       @unique
  password         String?
  name             String?
  createdAt        DateTime     @default(now())
  phone            String?
  profession       String?
  updatedAt        DateTime     @updatedAt
  role             UserRole     @default(STUDENT)
  googleId         String?      @unique
  resetToken       String?      @unique
  resetTokenExpiry DateTime?
  profileId        Int?
  enrollments      Enrollment[]
  profile          Profile?     @relation(fields: [profileId], references: [id])
}

model Course {
  id                       Int              @id @default(autoincrement())
  title                    String
  coverImage               String?
  startDate                DateTime?
  endDate                  DateTime?
  modality                 Modality         @default(VIRTUAL)
  capacity                 Int              @default(0)
  schedule                 String?
  description              String?
  targetAudience           String?
  status                   CourseStatus     @default(BORRADOR)
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
  confirmationEmail        String?
  confirmationEmailSubject String?
  objectives               String?
  courseProfiles           CourseProfile[]
  resources                CourseResource[]
  enrollments              Enrollment[]
  modules                  Module[]
  prices                   Price[]
}

model CourseProfile {
  id                Int     @id @default(autoincrement())
  courseId          Int
  profileId         Int
  capacity          Int     @default(0)
  requireCredential Boolean @default(false)
  course            Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  profile           Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([courseId, profileId])
}

model Module {
  id             Int            @id @default(autoincrement())
  courseId       Int
  name           String
  order          Int            @default(0)
  date           String?
  accessAll      Boolean        @default(true)
  topics         String[]
  course         Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  accessProfiles ModuleAccess[]
}

model ModuleAccess {
  moduleId  Int
  profileId Int
  module    Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@id([moduleId, profileId])
}

model Price {
  id        Int      @id @default(autoincrement())
  courseId  Int
  name      String
  amount    Float
  currency  String   @default("ARS")
  active    Boolean  @default(true)
  profileId Int?
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  profile   Profile? @relation(fields: [profileId], references: [id])
}

model Enrollment {
  id            Int              @id @default(autoincrement())
  courseId      Int
  userName      String
  email         String
  createdAt     DateTime         @default(now())
  userId        Int?
  notes         String?
  paidAt        DateTime?
  paymentMethod String?
  paymentRef    String?
  profileId     Int?
  receiptUrl    String?
  status        EnrollmentStatus @default(PENDIENTE_PAGO)
  credentialUrl String?
  course        Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  profile       Profile?         @relation(fields: [profileId], references: [id])
  user          User?            @relation(fields: [userId], references: [id])
}

model CourseResource {
  id        Int      @id @default(autoincrement())
  courseId  Int
  type      String
  title     String
  fileUrl   String?
  visible   Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Post {
  id         Int      @id @default(autoincrement())
  title      String
  slug       String   @unique
  excerpt    String?
  content    String
  coverImage      String?
  videoUrl        String?
  showCoverImage  Boolean  @default(true)
  published       Boolean  @default(false)
  order           Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Professional {
  id        Int      @id @default(autoincrement())
  name      String
  role      String
  bio       String?
  cvContent String?
  imageUrl  String?
  instagram String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Subscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model EmailLog {
  id        Int      @id @default(autoincrement())
  to        String
  subject   String
  status    String   // "SENT", "FAILED"
  error     String?
  type      String   // "TRANSACTIONAL", "BULK", "AUTH"
  createdAt DateTime @default(now())
}

enum UserRole {
  ADMIN
  STUDENT
}

enum CourseStatus {
  PUBLICADO
  BORRADOR
  CERRADO
}

enum Modality {
  VIRTUAL
  PRESENCIAL
  HIBRIDO
}

enum EnrollmentStatus {
  PENDIENTE_PAGO
  COMPROBANTE_SUBIDO
  CONFIRMADA
  CANCELADA
}
